<!DOCTYPE html>
@{
    var lang = Context.Request.Cookies["language"] ?? "en";
}

<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebApplication2</title>

    <!-- INLINE SCRIPT FOR IMMEDIATE THEME APPLICATION (PREVENTS FLASH) -->
    <script>
        // Get theme preference from local storage or default to light
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
        } else {
            // Set a default if no theme is saved yet
            document.documentElement.setAttribute('data-theme', 'light');
            localStorage.setItem('theme', 'light');
        }
    </script>

    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication2.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/main.css" media="all" /> <!-- Ensure media="all" is correct -->
    <!-- Font Awesome for light/dark mode icon and other icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <!--Navigation Bar Title-->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebApplication2</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index" data-translate="home">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy" data-translate="privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Report" data-translate="report">Report</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register" data-translate="register">Register</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="ResetPassword" data-translate="resetPassword">Reset Password</a>
                        </li>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="#" data-bs-toggle="modal" data-bs-target="#logoutModal" data-translate="logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login" data-translate="login">Login</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Category" asp-action="Index" data-translate="manageCategories">Manage Categories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Location" asp-action="Index" data-translate="manageLocations">Manage Locations</a>
                            </li>
                        }
                        <!-- Settings Button -->
                        <li class="nav-item ms-auto me-3">
                            <button id="settings-toggle" class="btn btn-link nav-link" data-bs-toggle="modal" data-bs-target="#settingsModal">
                                <i class="fas fa-cog"></i>
                                <span class="d-none d-sm-inline"></span>
                            </button>
                        </li>

                        <!-- Light / Dark Mode Toggle -->
                        <li class="nav-item">
                            <button id="theme-toggle" class="btn btn-link nav-link">
                                <i class="fas"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container" style="color: darkgrey;">
            &copy; 2025 - WebApplication2 - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="text-decoration: none;" data-translate="privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Logout Confirmation Modal -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="logoutModalLabel" data-translate="confirmLogout">Confirm Logout</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" data-translate="logoutMessage">
                    Are you sure you want to logout?
                </div>
                <div class="modal-footer">
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" data-translate="logout">Logout</button>
                    </form>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-translate="close">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Updated Settings Modal -->
    <div class="modal fade" id="settingsModal" tabindex="-1" aria-labelledby="settingsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="settingsModalLabel">Application Settings</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="languageSelect" class="form-label" data-translate="language">Language</label>
                        <select class="form-select" id="languageSelect">
                            <option value="en">English</option>
                            <option value="ms">Malay</option>
                            <option value="zh">Chinese</option>
                            <option value="ta">Tamil</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="" id="notificationsToggle">
                        <label class="form-check-label" for="notificationsToggle" data-translate="notifications">
                            Enable Notifications
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary me-3" data-bs-dismiss="modal" data-translate="close">Close</button>
                    <button type="button" class="btn btn-secondary" id="saveSettingsBtn" data-translate="save">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // JavaScript for theme toggling (interactive part)
        document.addEventListener('DOMContentLoaded', function () {
            const themeToggleBtn = document.getElementById('theme-toggle');
            const htmlElement = document.documentElement; // This is the <html> tag

            // Initial icon update based on the theme already set by the head script
            updateThemeIcon(htmlElement.getAttribute('data-theme'));

            themeToggleBtn.addEventListener('click', function () {
                const currentTheme = htmlElement.getAttribute('data-theme');
                const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                htmlElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme); // Save preference
                updateThemeIcon(newTheme);
            });

            function updateThemeIcon(theme) {
                const icon = themeToggleBtn.querySelector('i');
                if (theme === 'dark') {
                    icon.classList.remove('fa-moon');
                    icon.classList.add('fa-sun');
                } else {
                    icon.classList.remove('fa-sun');
                    icon.classList.add('fa-moon');
                }
            }
        });



        document.addEventListener('DOMContentLoaded', function() {
            // Initialize language from localStorage or browser setting
            const savedLanguage = localStorage.getItem('language') || navigator.language.split('-')[0];
            if (savedLanguage) {
                document.documentElement.lang = savedLanguage;
                document.getElementById('languageSelect').value = savedLanguage;
            }

            // Save settings handler
            document.getElementById('saveSettingsBtn').addEventListener('click', function() {
                const selectedLanguage = document.getElementById('languageSelect').value;

                // Save to localStorage
                localStorage.setItem('language', selectedLanguage);
                document.documentElement.lang = selectedLanguage;

                // Reload to apply translations
                location.reload();
            });

            // Apply translations based on current language
            applyTranslations(document.documentElement.lang);
        });

        // Translation function
        function applyTranslations(lang) {
            const translations = {
                en: {
                    'home': 'Home',
                    'privacy': 'Privacy',
                    'report': 'Report',
                    'register': 'Register',
                    'resetPassword': 'Reset Password',
                    'logout': 'Logout',
                    'login': 'Login',
                    'manageCategories': 'Manage Categories',
                    'manageLocations': 'Manage Locations',
                    'language': 'Language',
                    'notifications': 'Enable Notifications',
                    'close': 'Close',
                    'save': 'Save Changes',
                    'confirmLogout': 'Confirm Logout',
                    'logoutMessage': 'Are you sure you want to logout?'
                },
                ms: {
                    'home': 'Laman Utama',
                    'privacy': 'Privasi',
                    'report': 'Lapor',
                    'register': 'Daftar',
                    'resetPassword': 'Set Semula Kata Laluan',
                    'logout': 'Log Keluar',
                    'login': 'Log Masuk',
                    'manageCategories': 'Urus Kategori',
                    'manageLocations': 'Urus Lokasi',
                    'language': 'Bahasa',
                    'notifications': 'Hidupkan Pemberitahuan',
                    'close': 'Tutup',
                    'save': 'Simpan Perubahan',
                    'confirmLogout': 'Sahkan Log Keluar',
                    'logoutMessage': 'Adakah anda pasti mahu log keluar?'
                },
                zh: {
                    'home': '首页',
                    'privacy': '隐私',
                    'report': '报告',
                    'register': '注册',
                    'resetPassword': '重设密码',
                    'logout': '登出',
                    'login': '登录',
                    'manageCategories': '管理类别',
                    'manageLocations': '管理位置',
                    'language': '语言',
                    'notifications': '启用通知',
                    'close': '关闭',
                    'save': '保存更改',
                    'confirmLogout': '确认登出',
                    'logoutMessage': '您确定要登出吗？'
                },
                ta: {
                    'home': 'முகப்பு',
                    'privacy': 'தனியுரிமை',
                    'report': 'புகார்',
                    'register': 'பதிவு',
                    'resetPassword': 'கடவுச்சொல் மீட்டமை',
                    'logout': 'வெளியேறு',
                    'login': 'உள்நுழை',
                    'manageCategories': 'வகைகளை நிர்வகி',
                    'manageLocations': 'இடங்களை நிர்வகி',
                    'language': 'மொழி',
                    'notifications': 'அறிவிப்புகளை இயக்கு',
                    'close': 'மூடு',
                    'save': 'மாற்றங்களை சேமி',
                    'confirmLogout': 'வெளியேறுவதை உறுதிப்படுத்தவும்',
                    'logoutMessage': 'நீங்கள் வெளியேற விரும்புகிறீர்களா?'
                }
            };

            // Get translations for current language or fallback to English
            const langTranslations = translations[lang] || translations['en'];

            // Apply translations to all elements with data-translate attribute
            document.querySelectorAll('[data-translate]').forEach(element => {
                const key = element.getAttribute('data-translate');
                if (langTranslations[key]) {
                    element.textContent = langTranslations[key];
                }
            });
        }
    </script>

</body>

@if (User.Identity.IsAuthenticated)
{
    <!-- The old logout form is now handled by the modal above -->
}

</html>
