<div class="container">
    <form asp-controller="Home" asp-action="SubmitReport" method="post" enctype="multipart/form-data" class="form">
        <div>
            <label for="userInput">User</label>
            <input type="text" id="userInput" name="UserName" />
        </div>
        <div>
            <label for="descriptionInput">Description</label>
            <textarea id="descriptionInput" name="Description" rows="4"></textarea>
        </div>
        <div>
            <label for="fileInput">Attachments</label>
            <input type="file" id="fileInput" name="Attachments" multiple />
        </div>
        <button type="submit">Submit Report</button>
    </form>
</div>

<style>
    .form textarea {
        width: 100%;
        padding: 0.75rem;
        border: 2px solid #e2e8f0;
        border-radius: 6px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }
</style>

<link href="~/css/main.css" rel="stylesheet" media="all" />